#!/bin/sh

# Skip during rebase operations
if [ -n "$GIT_REFLOG_ACTION" ] && [ "$GIT_REFLOG_ACTION" = "rebase" ]; then
  exit 0
fi
if [ -d ".git/rebase-merge" ] || [ -d ".git/rebase-apply" ]; then
  exit 0
fi

# Check for package.json changes and update dependencies
PREV_COMMIT=$(git rev-parse "$1")
CURR_COMMIT=$(git rev-parse "$2")

if git diff --name-only "$PREV_COMMIT" "$CURR_COMMIT" | grep -q '^package.json$'; then
  echo "package.json changed, installing dependencies..."
  # Try to use NVM if available, otherwise continue with current node
  if [ -s "$HOME/.nvm/nvm.sh" ]; then
    . "$HOME/.nvm/nvm.sh"
    nvm use
  fi
  npm install --frozen-lockfile
fi
